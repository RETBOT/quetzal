#!/bin/bash
# =============================================================================
# Quetzal Project Init Command
# Inicializa un proyecto nuevo con Quetzal
# =============================================================================

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

echo -e "${CYAN}${BOLD}"
echo "  🦜 Quetzal Project Init"
echo "  ========================"
echo -e "${NC}"

# Detectar si estamos en un proyecto
detect_project() {
    echo -e "${BLUE}[detect]${NC} Analizando proyecto..."
    
    local project_type="unknown"
    local has_git=false
    local has_package_json=false
    
    if [ -d ".git" ]; then
        has_git=true
        echo -e "  ${GREEN}✓${NC} Git repository detectado"
    fi
    
    if [ -f "package.json" ]; then
        has_package_json=true
        echo -e "  ${GREEN}✓${NC} package.json encontrado"
        
        # Detectar framework
        if grep -q "react" package.json 2>/dev/null; then
            project_type="react"
        elif grep -q "vue" package.json 2>/dev/null; then
            project_type="vue"
        elif grep -q "@angular" package.json 2>/dev/null; then
            project_type="angular"
        elif grep -q "next" package.json 2>/dev/null; then
            project_type="nextjs"
        elif grep -q "svelte" package.json 2>/dev/null; then
            project_type="svelte"
        else
            project_type="node"
        fi
    fi
    
    if [ -f "Cargo.toml" ]; then
        project_type="rust"
        echo -e "  ${GREEN}✓${NC} Proyecto Rust detectado"
    elif [ -f "go.mod" ]; then
        project_type="go"
        echo -e "  ${GREEN}✓${NC} Proyecto Go detectado"
    elif [ -f "requirements.txt" ] || [ -f "pyproject.toml" ]; then
        project_type="python"
        echo -e "  ${GREEN}✓${NC} Proyecto Python detectado"
    fi
    
    echo -e "${GREEN}✓${NC} Tipo de proyecto: ${BOLD}$project_type${NC}"
    
    # Guardar en variable global
    PROJECT_TYPE=$project_type
}

# Crear estructura de carpetas
create_structure() {
    echo ""
    echo -e "${CYAN}${BOLD}==>${NC} ${BOLD}Creando estructura Quetzal...${NC}"
    
    # Crear carpeta .quetzal
    mkdir -p .quetzal
    
    # Crear archivos de configuración
    cat > .quetzal/config.json << EOF
{
  "version": "1.0",
  "project_type": "$PROJECT_TYPE",
  "initialized": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "modes": {
    "default": "strict",
    "available": ["strict", "fast", "team"]
  },
  "workflows_enabled": true
}
EOF
    
    echo -e "${GREEN}✓${NC} Configuración creada (.quetzal/config.json)"
}

# Crear .engram para el proyecto
setup_engram() {
    echo ""
    echo -e "${CYAN}${BOLD}==>${NC} ${BOLD}Configurando Engram...${NC}"
    
    if [ ! -d ".engram" ]; then
        mkdir -p .engram
        
        # Detectar nombre del proyecto
        local project_name=$(basename "$(pwd)")
        
        cat > .engram/project.json << EOF
{
  "name": "$project_name",
  "type": "$PROJECT_TYPE",
  "description": "Proyecto gestionado por Quetzal",
  "initialized": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "auto_sync": true,
  "conventions": []
}
EOF
        
        echo -e "${GREEN}✓${NC} Engram configurado (.engram/project.json)"
    else
        echo -e "${YELLOW}⚠${NC} Engram ya estaba configurado"
    fi
}

# Setup de git hooks (opcional)
setup_git_hooks() {
    echo ""
    echo -e "${CYAN}${BOLD}==>${NC} ${BOLD}Configurando Git hooks...${NC}"
    
    if [ -d ".git" ]; then
        # Pre-commit hook básico
        cat > .git/hooks/pre-commit << 'EOF'
#!/bin/bash
# Quetzal Pre-commit Hook
echo "🦜 Quetzal: Verificando antes de commit..."

# Aquí puedes agregar validaciones
# - Linting
# - Tests
# - Formato

echo "✓ Pre-commit completado"
EOF
        
        chmod +x .git/hooks/pre-commit
        echo -e "${GREEN}✓${NC} Pre-commit hook instalado"
    fi
}

# Mensaje final
print_completion() {
    echo ""
    echo -e "${GREEN}${BOLD}✅ Proyecto inicializado con Quetzal!${NC}"
    echo ""
    echo -e "${CYAN}${BOLD}Próximos pasos:${NC}"
    echo -e "  1. ${BOLD}./sdd-init${NC}     → Configurar SDD para tu stack"
    echo -e "  2. ${BOLD}skill-registry${NC} → Registrar skills disponibles"
    echo -e "  3. ${BOLD} Abrir OpenCode${NC} → Empezar a trabajar con Quetzal"
    echo ""
    echo -e "${DIM}Config: .quetzal/config.json${NC}"
    echo -e "${DIM}Docs: https://github.com/RETBOT/quetzal${NC}"
}

# Main
main() {
    detect_project
    create_structure
    setup_engram
    setup_git_hooks
    print_completion
}

main "$@"
